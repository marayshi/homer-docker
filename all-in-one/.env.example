# Homer 10 Production Environment
# Copy this file to .env and fill in real values:
#   cp .env.example .env

# Grafana admin credentials
ADMIN_USER=admin
ADMIN_PASSWORD=<your-grafana-password>
# Public URL for Grafana (used for links in alerts, etc.)
GRAFANA_ROOT_URL=http://localhost:3000
# Bind address — 0.0.0.0:3000 exposes to all interfaces, 127.0.0.1:3000 for localhost only
GRAFANA_LISTEN=0.0.0.0:3000

# ClickHouse credentials (must match across both vars)
CLICKHOUSE_USER=qryn
CLICKHOUSE_PASSWORD=<your-clickhouse-password>
CLICKHOUSE_AUTH=qryn:<your-clickhouse-password>

# HEP listener — where Kamailio sends SIP traces
# 127.0.0.1:9060 if Kamailio is on the same host
# 0.0.0.0:9060 if Kamailio sends from a remote server
HEP_LISTEN=127.0.0.1:9060
